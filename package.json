{
  "name": "nbs-workspace",
  "private": true,
  "workspaces": [
    "packages/nbs-root",
    "packages/nbs-test"
  ],
  "scripts": {
    "dev:test": "npm run dev -w nbs-test",
    "build:test:prod": "npm run build:prod -w nbs-test",
    "build:test:staging": "npm run build:staging -w nbs-test",
    "build-ssg:test:prod": "npm run build-ssg:prod -w nbs-test",
    "build-ssg:test:staging": "npm run build-ssg:staging -w nbs-test",
    "build-ai:test:prod": "npm run build-ai:prod -w nbs-test",
    "build-ai:test:staging": "npm run build-ai:staging -w nbs-test",
    "lint:test": "npm run lint -w nbs-test",
    "pack:root": "npm pack -w nbs-root",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint --edit $1"
  }
}
